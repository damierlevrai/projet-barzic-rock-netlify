CREATE POLICY "Public view establishment photos" ON storage.objects FOR SELECT USING ((bucket_id = 'establishment-photos'::text));


--
-- Name: objects Public view event photos; Type: POLICY; Schema: storage; Owner: supabase_storage_admin
--

CREATE POLICY "Public view event photos" ON storage.objects FOR SELECT USING ((bucket_id = 'event-photos'::text));


