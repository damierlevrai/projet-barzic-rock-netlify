-- Name: app_metadata admin_app_metadata; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY admin_app_metadata ON public.app_metadata USING ((auth.uid() IN ( SELECT profiles.id
   FROM public.profiles
  WHERE (profiles.role = 'admin'::text)))) WITH CHECK ((auth.uid() IN ( SELECT profiles.id
   FROM public.profiles
  WHERE (profiles.role = 'admin'::text))));


